{
  "name": "claude-wrapped-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for claude-wrapped: the CLI (apps/cli) and the marketing/docs site (apps/web).",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  },
  "packageManager": "bun@1.2.19",
  "engines": {
    "node": ">=18"
  }
}
