{
  "name": "claude-wrapped-cli",
  "version": "0.1.1",
  "description": "Spotify-Wrapped-style summary image of your Claude Code usage.",
  "author": "Lucas Amberg",
  "homepage": "https://claude-wrapped-zeta.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucas-amberg/claude-wrapped.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/lucas-amberg/claude-wrapped/issues"
  },
  "type": "module",
  "bin": {
    "claude-wrapped-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs/sample.png",
    "docs/sample-dark.png",
    "README.md",
    "LICENSE",
    "OFL.txt"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "claude",
    "claude-code",
    "wrapped",
    "ccusage",
    "cli",
    "usage",
    "tokens"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "open": "^11.0.0",
    "cac": "^7.0.0",
    "satori": "^0.26.0",
    "ultrahtml": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
